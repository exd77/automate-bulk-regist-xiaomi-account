# 2Captcha API key (required)
TWOCAPTCHA_API_KEY=your_2...n
# Gmail for receiving verification emails (required)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_g...n
# Domain(s) for email aliases - comma-separated for rotation (required)
DOMAIN=yourdomain.com

# Password for registered accounts (default: Xiaomigey1!)
PASSWORD=*** Referral code to bind after registration (required)
REFERRAL_CODE=XXXXXX

# Referral delay in seconds (default: 120)
REFERRAL_DELAY=120

# Number of accounts to register (default: 5)
COUNT=5

# Proxy (optional) - format: http://user:***@host:port
PROXY_URL=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELE...
