# Capsolver API key (required)
TWO...your_capsolver_key_here
# Gmail for receiving verification emails (required)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password
# Domain(s) for email aliases - comma-separated for rotation (required)
DOMAIN=yourdomain.com

# Password for registered accounts (default: Xiaomigey1!)
PASSWORD=Xiaomigey1!
# Referral code to bind after registration (required)
REFERRAL_CODE=XXXXXX

# Referral delay in seconds (default: 120)
REFERRAL_DELAY=120

# Number of accounts to register (default: 5)
COUNT=5

# Proxy (optional) - format: http://user:***@host:port
PROXY_URL=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Chain Referral Mode ──
# Enable chain referral: each account's refCode seeds the next (true/false)
CHAIN_REFERRAL=false
# Seed invite code for first iteration (used when CHAIN_REFERRAL=true)
CHAIN_SEED=XXXXXX
# Auto-fill Ultraspeed beta form after registration (true/false)
ULTRASPEED_FORM=false
# Auto-create API key after registration (true/false)
CRE...e
